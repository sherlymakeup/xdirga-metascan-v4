# Copy this file to backend/.env, replace every placeholder, never commit backend/.env.
# Numeric MT5 account login.
MT5_LOGIN=REPLACE_WITH_MT5_LOGIN
# MT5 account password.
MT5_PASSWORD=REPLACE_WITH_MT5_PASSWORD
# Exact broker server name shown by MT5.
MT5_SERVER=REPLACE_WITH_MT5_SERVER
# Random secret used only for dashboard Bearer authentication.
API_TOKEN=REPLACE_WITH_RANDOM_DASHBOARD_TOKEN
